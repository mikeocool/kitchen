#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KITCHEN_WORKSPACE="$(realpath "${1:-$PWD}")"
KITCHEN_NAME="$(basename "$KITCHEN_WORKSPACE")"

if [[ -f "${KITCHEN_WORKSPACE}/.kitchen/.env" ]]; then
    source "${KITCHEN_WORKSPACE}/.kitchen/.env"
fi

if [[ -f "${KITCHEN_WORKSPACE}/.kitchenenv" ]]; then
    source "${KITCHEN_WORKSPACE}/.kitchenenv"
fi

if [[ -f "${KITCHEN_WORKSPACE}/.kitchen/.env.local" ]]; then
    source "${KITCHEN_WORKSPACE}/.kitchen/.env.local"
fi

if [[ -f "${KITCHEN_WORKSPACE}/.kitchenenv.local" ]]; then
    source "${KITCHEN_WORKSPACE}/.kitchenenv.local"
fi

if docker inspect --type container "${KITCHEN_NAME}-kitchen" &>/dev/null; then
    STATE="$(docker inspect --type container -f '{{.State.Status}}' "${KITCHEN_NAME}-kitchen")"

    if [[ "${STATE}" == "exited" ]]; then
        # TODO maybe support restarting containers -- maybe only rm
        # if we build the image and it has changed or the args are going to change?
        echo "Removing old ${KITCHEN_NAME}-kitchen container."
        docker rm "${KITCHEN_NAME}-kitchen"
    else
        echo "${KITCHEN_NAME}-kitchen already exists. State: ${STATE}"
        exit 1
    fi
fi

echo "Starting ${KITCHEN_NAME}-kitchen..."

docker build -t "${KITCHEN_NAME}-kitchen" "${SCRIPT_DIR}"

MOUNT_ARGS=()
if [[ -n "${KITCHEN_MOUNTS:-}" ]]; then
    for mount in ${KITCHEN_MOUNTS}; do
        MOUNT_ARGS+=(--mount "${mount}")
    done
fi

NETWORK_ARGS=()
if [[ -n "${KITCHEN_NETWORK:-}" ]]; then
    if ! docker network inspect "${KITCHEN_NETWORK}" &>/dev/null; then
        echo "Creating docker network ${KITCHEN_NETWORK}..."
        docker network create "${KITCHEN_NETWORK}"
    fi
    NETWORK_ARGS=(--network "${KITCHEN_NETWORK}")
fi

docker run -d --name "${KITCHEN_NAME}-kitchen" \
    --hostname "${KITCHEN_NAME}-kitchen" \
    -v "${KITCHEN_WORKSPACE}:/workspaces/${KITCHEN_NAME}" \
    -v /var/run/docker.sock:/var/run/docker.sock \
    -e "KITCHEN_WORKSPACE=/workspaces/${KITCHEN_NAME}" \
    "${MOUNT_ARGS[@]}" \
    "${NETWORK_ARGS[@]}" \
    "${KITCHEN_NAME}-kitchen"

while read -r line; do
    echo "$line"
    if [[ "$line" == *"Kitchen is ready to cook"* ]]; then
        break
    fi
done < <(docker logs -f "${KITCHEN_NAME}-kitchen" 2>&1)

sleep 1
if ! docker inspect -f '{{.State.Running}}' "${KITCHEN_NAME}-kitchen" 2>/dev/null | grep -q true; then
    echo "Error: ${KITCHEN_NAME}-kitchen failed to start" >&2
    exit 1
fi
