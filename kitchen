#!/bin/bash

set -euo pipefail

WORKSPACE="$(realpath "$1")"
KITCHEN_NAME="$(basename "$WORKSPACE")"

echo "Starting ${KITCHEN_NAME}-kitchen..."

docker build -t "${KITCHEN_NAME}-kitchen" .

docker run -d --name "${KITCHEN_NAME}-kitchen" \
    --hostname "${KITCHEN_NAME}-kitchen" \
    -v "${WORKSPACE}:/workspaces/${KITCHEN_NAME}" \
    -v /var/run/docker.sock:/var/run/docker.sock \
    "${KITCHEN_NAME}-kitchen"

while read -r line; do
    echo "$line"
    if [[ "$line" == *"Kitchen is ready to cook"* ]]; then
        break
    fi
done < <(docker logs -f "${KITCHEN_NAME}-kitchen" 2>&1)

sleep 1
if ! docker inspect -f '{{.State.Running}}' "${KITCHEN_NAME}-kitchen" 2>/dev/null | grep -q true; then
    echo "Error: ${KITCHEN_NAME}-kitchen failed to start" >&2
    exit 1
fi
